# =============================================================================
# Energy Intelligence — Environment Variables
#
# Copy this file to .env and fill in values:
#   cp .env.example .env
#
# Docker Compose reads .env automatically.
# For local dev without Docker, export these or use: source .env
# =============================================================================

# --- Database (TimescaleDB / PostgreSQL) ---
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://energy:${POSTGRES_PASSWORD}@localhost:5432/energy_intelligence

# --- Session ---
# Required. Use a long random string in production (e.g. openssl rand -base64 32)
SESSION_SECRET=change-me-in-production

# --- Admin seed user ---
# Password for the default admin account created by `npm run db:seed`
ADMIN_PASSWORD=change-me

# --- Prediction service ---
PREDICTION_SERVICE_URL=http://localhost:8001

# --- Server ---
PORT=5000
NODE_ENV=development
